---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
---

<style>
  .about-hero {
    background: var(--grad-hero);
    padding: 4.5rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid var(--border);
  }
  .about-hero h1 { margin-bottom: 0.75rem; }
  .about-hero .lead { max-width: 600px; margin-inline: auto; }

  .about-content {
    max-width: 820px;
    margin-inline: auto;
    padding: 4rem 1.5rem;
    display: grid;
    gap: 3rem;
  }
  .about-logo-block {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .about-logo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 3px solid var(--border);
    box-shadow: var(--shadow-md);
    flex-shrink: 0;
    object-fit: cover;
  }
  .about-logo-text h2 { margin-bottom: 0.5rem; }
  .about-logo-text p  { color: var(--text-muted); margin: 0; }

  .about-block {}
  .about-block h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }
  .about-block p { line-height: 1.8; color: var(--text-body); margin-bottom: 1rem; }
  .about-block ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .about-block ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--text-body);
    background: var(--off-white);
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    font-family: var(--font-head);
    font-weight: 600;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .value-card {
    background: var(--off-white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
  }
  .value-card .icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .value-card h4 { font-size: 0.95rem; margin-bottom: 0.35rem; }
  .value-card p  { font-size: 0.85rem; color: var(--text-muted); margin: 0; line-height: 1.5; }

  .notice-box {
    background: #FFFBE6;
    border: 1.5px solid #FFD700;
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--text-body);
  }
  .notice-box strong { color: var(--text-dark); }
</style>

<BaseLayout
  title="About Smart Reward Finds"
  description="Learn what Smart Reward Finds is, how it works, and why it exists — a curated resource for legit gift card giveaways, smart tools, trusted offers, and useful product finds."
>

  <section class="about-hero">
    <div class="container">
      <span class="section-label" style="justify-content:center">About Us</span>
      <h1>About Smart Reward Finds</h1>
      <p class="lead text-muted">
        A curated resource for legit gift card giveaways, helpful tools, trusted offers,
        and useful finds — explained clearly for real people.
      </p>
    </div>
  </section>

  <div class="about-content container">

    <!-- Logo block -->
    <div class="about-logo-block">
      <img src="/images/logo.png" alt="Smart Reward Finds Logo" class="about-logo" width="140" height="140" />
      <div class="about-logo-text">
        <h2>Smart Reward Finds</h2>
        <p>Legit Finds. Real Rewards. Smarter You.</p>
        <span class="badge badge-coral" style="margin-top:0.5rem">Content Resource Blog</span>
      </div>
    </div>

    <!-- What we are -->
    <div class="about-block">
      <h2>What Is Smart Reward Finds?</h2>
      <p>
        Smart Reward Finds is a curated content blog built around one idea: helping everyday people discover
        legitimate reward opportunities, useful tools, and honest product finds — without the hype,
        fake urgency, or misleading promises you see on so many other sites.
      </p>
      <p>
        We publish beginner-friendly guides, breakdowns, and resource lists covering topics like:
      </p>
      <ul>
        <li>🎁 Gift card giveaway platforms</li>
        <li>💡 Smart tools worth checking out</li>
        <li>📱 Legitimate reward apps</li>
        <li>✨ Exclusive offers explained</li>
        <li>🛍️ Useful product finds</li>
        <li>📖 How-to guides for beginners</li>
      </ul>
      <p>
        We're not a giveaway site. We don't run the offers we write about. We're a resource hub —
        a place to come and learn about what's out there before you decide whether something's worth your time.
      </p>
    </div>

    <!-- Why we exist -->
    <div class="about-block">
      <h2>Why Smart Reward Finds Exists</h2>
      <p>
        If you've ever searched online for "legit gift card reward apps" or "ways to earn rewards online,"
        you've probably seen a mix of useful content and a lot of garbage — fake reviews, misleading claims,
        and sites that care more about getting you to click than actually helping you.
      </p>
      <p>
        Smart Reward Finds started to fill a different kind of role: a place where the content is actually
        helpful, the writing is honest about what we know and don't know, and the experience doesn't feel
        like being pushed into something before you're ready.
      </p>
      <p>
        We try to be the friend who's done the research and can give you a real, no-nonsense take —
        not a polished pitch.
      </p>
    </div>

    <!-- Values -->
    <div class="about-block">
      <h2>How We Approach This</h2>
      <div class="values-grid">
        <div class="value-card">
          <div class="icon">🔍</div>
          <h4>Curated Finds</h4>
          <p>We only share things we think are worth sharing. Not every offer is worth your time, and we try to say so when it's not.</p>
        </div>
        <div class="value-card">
          <div class="icon">📝</div>
          <h4>Plain Language</h4>
          <p>Jargon-free guides. We explain things the way you'd want a friend to, not the way a marketer would.</p>
        </div>
        <div class="value-card">
          <div class="icon">🤝</div>
          <h4>Honest About Links</h4>
          <p>Some links earn us a small commission. We disclose this openly. It doesn't change what we recommend.</p>
        </div>
        <div class="value-card">
          <div class="icon">⚠️</div>
          <h4>Third-Party Clarity</h4>
          <p>We're a content site. We don't run the offers, tools, or platforms we write about. Always check official sources.</p>
        </div>
        <div class="value-card">
          <div class="icon">🔄</div>
          <h4>Updated When Possible</h4>
          <p>Offers change. We update content when we can and always recommend checking the official provider for current info.</p>
        </div>
        <div class="value-card">
          <div class="icon">🧭</div>
          <h4>No Fake Urgency</h4>
          <p>No fake countdowns. No "limited time only" pressure tactics. Just honest information so you can decide.</p>
        </div>
      </div>
    </div>

    <!-- Important note -->
    <div class="notice-box">
      <strong>📌 Important Note:</strong> Smart Reward Finds is an independent content website.
      We share informational content about third-party tools, reward platforms, gift card offers, and related resources.
      We are not affiliated with, operated by, or endorsed by any of the third-party services we write about unless
      explicitly stated. We do not manage third-party accounts, handle payouts, or provide customer support for
      external services. Always contact the official provider directly for account-specific questions.
    </div>

  </div>

  <!-- CTA -->
  <div class="container" style="padding-bottom:5rem">
    <CTABlock
      heading="Explore the Blog"
      subtext="Browse our guides on gift cards, smart tools, reward apps, and trusted offers."
      primaryLabel="View All Guides"
      primaryHref="/blog"
      secondaryLabel="Get in Touch"
      secondaryHref="/contact"
      variant="light"
    />
  </div>

</BaseLayout>
