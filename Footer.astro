---
// src/components/Footer.astro
// EDIT: Update Pinterest URL, copyright year auto-updates
const year = new Date().getFullYear();
const pinterestUrl = "https://pinterest.com/smartrewardfinds"; // EDIT: Your Pinterest URL
---

<style>
  footer {
    background: var(--navy);
    color: rgba(255,255,255,0.75);
    padding: 3.5rem 0 0;
    margin-top: auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }
  .footer-brand {}
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .footer-logo img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.2);
  }
  .footer-logo-text {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 1.05rem;
    color: var(--white);
    line-height: 1.1;
  }
  .footer-logo-text span { color: var(--yellow); }
  .footer-tagline {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }
  .footer-social {
    display: flex;
    gap: 0.75rem;
  }
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: var(--white);
    transition: background 0.2s, transform 0.2s;
    font-size: 0.9rem;
  }
  .social-link:hover { background: var(--coral); transform: translateY(-2px); }

  .footer-col h4 {
    font-family: var(--font-head);
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--white);
    margin-bottom: 1rem;
  }
  .footer-links { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-links a {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--yellow); }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .footer-bottom p {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
  }
  .footer-bottom-links {
    display: flex;
    gap: 1rem;
  }
  .footer-bottom-links a {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    transition: color 0.2s;
  }
  .footer-bottom-links a:hover { color: var(--white); }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>

<footer>
  <div class="container">
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/images/logo.png" alt="Smart Reward Finds" width="44" height="44" />
          <span class="footer-logo-text">Smart <span>Reward</span><br/>Finds</span>
        </div>
        <p class="footer-tagline">
          Your curated resource for legit gift card giveaways, smart tools,
          trusted offers, and useful product finds. Legit Finds. Real Rewards.
        </p>
        <!-- EDIT: Update Pinterest link -->
        <div class="footer-social">
          <a href={pinterestUrl} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Follow us on Pinterest">
            <!-- Pinterest SVG icon -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation column -->
      <div class="footer-col">
        <h4>Navigate</h4>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </div>
      </div>

      <!-- Legal column -->
      <div class="footer-col">
        <h4>Legal & Trust</h4>
        <div class="footer-links">
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/affiliate-disclosure">Affiliate Disclosure</a>
          <a href="/disclaimer">Disclaimer</a>
          <a href="/editorial-policy">Editorial Policy</a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <!-- EDIT: Update brand name if needed -->
      <p>&copy; {year} Smart Reward Finds. All rights reserved. We share informational content only. Third-party offers and services are independent of this site.</p>
      <div class="footer-bottom-links">
        <a href="/privacy-policy">Privacy</a>
        <a href="/affiliate-disclosure">Disclosure</a>
        <a href="/disclaimer">Disclaimer</a>
      </div>
    </div>
  </div>
</footer>
